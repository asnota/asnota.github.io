---
import { Icon } from "astro-icon/components";

const menuItems = [
  { name: "Home", href: "/" },
  { name: "Blog", href: "/blog" },
  { name: "Compositions", href: "/compositions" },
  { name: "Achievements", href: "/achievements" },
  { name: "Press", href: "/press" },
];
---

<header
  class="sticky top-0 z-50 flex items-center justify-between border-b-border bg-background px-4 transition-shadow duration-200"
>
  <button
    id="menu-toggle"
    class="hamburger-container flex h-9 w-9 items-center justify-center"
    aria-label="Toggle menu"
    aria-expanded="false"
  >
    <div class="hamburger-lines">
      <span class="line line1"></span>
      <span class="line line2"></span>
      <span class="line line3"></span>
    </div>
  </button>
  <h1 class="flex-grow text-center">Anna Shvets</h1>
  <button
    type="button"
    class="inline-flex w-9 items-center"
    data-aw-toggle-color-scheme
  >
    <Icon name="tabler:sun" class="h-9 w-9 text-primary" />
  </button>
</header>

<nav
  id="mobile-menu"
  class="fixed left-0 z-40 h-[100vh] w-full -translate-x-full bg-background transition-transform duration-300"
>
  <ul class="flex h-full flex-col items-center justify-center gap-8 text-2xl">
    {
      menuItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="block px-8 py-4 transition-colors hover:text-primary"
          >
            {item.name}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<!-- TODO see if I can replace some px value and if I can better integrate with tailwind -->
<style>
  .hamburger-lines {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 26px;
    width: 32px;

    .line {
      display: block;
      height: 4px;
      width: 100%;
      border-radius: 10px;
      background: var(--primary);
    }

    .line1 {
      transform-origin: 0% 0%;
      transition: transform 0.4s ease-in-out;
    }

    .line2 {
      transition: transform 0.2s ease-in-out;
    }

    .line3 {
      transform-origin: 0% 100%;
      transition: transform 0.4s ease-in-out;
    }
  }

  .hamburger-container.active {
    .line1 {
      transform: rotate(45deg);
    }

    .line2 {
      transform: scaleY(0);
    }

    .line3 {
      transform: rotate(-45deg);
    }
  }
</style>

<script>
  const menuToggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");

  menuToggle?.addEventListener("click", () => {
    const isExpanded = menuToggle.getAttribute("aria-expanded") === "true";
    menuToggle.setAttribute("aria-expanded", String(!isExpanded));
    menuToggle.classList.toggle("active");
    mobileMenu?.classList.toggle("-translate-x-full");
  });

  document.addEventListener("click", (e) => {
    if (
      !menuToggle?.contains(e.target as Node) &&
      !mobileMenu?.contains(e.target as Node)
    ) {
      menuToggle?.setAttribute("aria-expanded", "false");
      menuToggle?.classList.remove("active");
      mobileMenu?.classList.add("-translate-x-full");
    }
  });

  function toggleTheme() {
    const documentElement = document.documentElement;
    documentElement.classList.toggle("dark");

    // Optional: Save preference to localStorage
    const isDark = documentElement.classList.contains("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
  }

  document
    .querySelectorAll("[data-aw-toggle-color-scheme]")
    .forEach((btn) => btn.addEventListener("click", toggleTheme));
</script>
